# Copy to `.env` and adjust as needed. docker-compose reads these automatically.

# PostgreSQL credentials (used by both the db and app services)
POSTGRES_DB=orders
POSTGRES_USER=orders
POSTGRES_PASSWORD=orders

# --- Only needed when running the app outside docker-compose (e.g. ./mvnw spring-boot:run) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orders
# SPRING_DATASOURCE_USERNAME=orders
# SPRING_DATASOURCE_PASSWORD=orders

# Background job interval in ms (optional; default 5 minutes)
# ORDERS_PROMOTE_FIXED_RATE_MS=300000
